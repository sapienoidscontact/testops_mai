{
  "name": "mai0.1",
  "version": "0.1.3",
  "private": true,
  "description": "M.AI0.1 — Personal AI assistant. Multi-provider routing, zero paid services.",
  "type": "module",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev":         "node scripts/dev.js",
    "build":       "pnpm -r run build",
    "start":       "node core/orchestrator/index.js",
    "intake":      "node scripts/intake.js",
    "health":      "node scripts/health-check.js",
    "setup":       "node scripts/setup.js",
    "test":        "node --experimental-vm-modules node_modules/.bin/jest",
    "lint":        "eslint . --ext .js,.jsx,.ts,.tsx",
    "docker:up":   "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f"
  },
  "workspaces": [
    "apps/*",
    "core",
    "packages/*"
  ],
  "dependencies": {
    "@google/generative-ai":    "^0.21.0",
    "groq-sdk":                 "^0.9.0",
    "ioredis":                  "^5.3.2",
    "express":                  "^4.19.2",
    "ws":                       "^8.17.1",
    "zod":                      "^3.23.8",
    "dotenv":                   "^16.4.5",
    "ajv":                      "^8.17.1",
    "node-fetch":               "^3.3.2",
    "cors":                     "^2.8.5",
    "helmet":                   "^7.1.0",
    "pino":                     "^9.3.1",
    "pino-pretty":              "^11.2.1",
    "uuid":                     "^11.0.0"
  },
  "devDependencies": {
    "eslint":   "^8.57.0",
    "jest":     "^29.7.0",
    "nodemon":  "^3.1.4"
  }
}
