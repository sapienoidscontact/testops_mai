# ═══════════════════════════════════════════════════════
#  M.AI0.1 — Environment Variables
#  Copy to .env — but API keys go in the UI, not here.
# ═══════════════════════════════════════════════════════

# ─── Deployment ───────────────────────────────────────
NODE_ENV=production
PORT=3001
BASE_URL=http://localhost:3001
PUBLIC_URL=https://mai01.REGION.azurecontainerapps.io

# ─── API Keys — OPTIONAL server-side fallbacks ────────
#
# M.AI0.1 is BYOK: each user enters their own API keys
# in the browser settings panel. Keys live in their
# localStorage and travel as request headers — the server
# never stores them.
#
# These .env entries are fallbacks ONLY — useful if you
# are running a private single-user instance and don't
# want to re-enter keys in the browser after every clear.
# Leave blank for the default shared/public experience.
#
# All free. All no-card-required.
# Get keys: https://aistudio.google.com/apikey (Gemini)
#           https://console.groq.com           (Groq)
#           https://cloud.cerebras.ai          (Cerebras)
#           https://cloud.sambanova.ai         (SambaNova)
#           https://huggingface.co/settings/tokens

GEMINI_API_KEY=
GROQ_API_KEY=
CEREBRAS_API_KEY=
SAMBANOVA_API_KEY=
HUGGINGFACE_API_KEY=
OPENROUTER_API_KEY=

# ─── Redis (Upstash — free serverless Redis, no card) ─
# Get free DB at https://upstash.com → Create Database → copy REST URL
REDIS_URL=rediss://default:YOUR_PASSWORD@YOUR_REGION.upstash.io:6380

# ─── Infrastructure ───────────────────────────────────
DATA_DIR=./data
SELF_MOD_ENABLED=true
PANIC_STOP_ENABLED=true
